// Prisma schema for 魔法日记本
// 运行迁移: pnpm prisma migrate dev
// 生成 Client: pnpm prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"        // 数据库类型
  url       = env("DATABASE_URL") // 给 应用 用
  directUrl = env("DIRECT_URL")   // 给 migrate 用
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
