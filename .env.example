# Auth.js (NextAuth v5)
AUTH_SECRET=  # 运行 npx auth secret 生成

# Prisma / Supabase PostgreSQL（双连接，从 Dashboard Connect 复制）
# DATABASE_URL：Transaction 模式 (6543)，应用运行时
# DIRECT_URL：Session 模式 (5432)，prisma migrate 必须用此
DATABASE_URL=
DIRECT_URL=

# Supabase Storage（日记图片存储）
# 注意：使用「项目 URL」和「service_role 密钥」，不是 Storage S3 的 endpoint 和 Secret access key
# 获取位置：Supabase Dashboard → Project Settings → API
#   - NEXT_PUBLIC_SUPABASE_URL：Project URL（如 https://xxxx.supabase.co）
#   - SUPABASE_SERVICE_ROLE_KEY：Project API keys → service_role（JWT，以 eyJ 开头）
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 火山方舟大模型（老朋友 AI 对话）
# 获取：火山方舟控制台
HUOSHAN_MODEL_API_KEY=
# 模型 Endpoint ID（如 glm-4-7-251222）
HUOSHAN_MODEL_ID=
